set from = "famous.jingo@meshle.com"
# set sendmail = "/usr/local/bin/msmtp -a meshle"

# Set folders
set spoolfile = "+meshle/INBOX"
set mbox = "+meshle/archive"
set postponed = "+meshle/drafts"
set record = "+meshle/sent"
set trash = "+meshle/trash"

# custom signaure
set signature = ~/.config/neomutt/signatures/default

color status cyan default

macro index o "<shell-escape>mbsync meshle<enter>" "run mbsync to sync mail for this account"

macro index,pager J \
  "<enter-command>set my_old_resolve=\$resolve noresolve<enter>\
  <tag-prefix><clear-flag>n<enter-command>set resolve=\$my_old_resolve<enter>\
  <save-message>+meshle/junk<enter>" \
  "mark as read and move to junk folder"

macro index,pager A \
  "<save-message>+meshle/archive<enter>"  \
  "move message to the archive"

macro index,pager I \
  "<save-message>+meshle/INBOX<enter>"  \
  "move message to the inbox"
