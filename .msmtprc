# Set default values for all following accounts.
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

# Gmail
account        gmail
host           smtp.gmail.com
port           587
from           jfamousekt@gmail.com
user           jfamousket@gmail.com
passwordeval    "gpg --quiet --for-your-eyes-only --no-tty --decrypt ~/.config/neomutt/passwords/account.gpg"

# Set a default account
account default : gmail
